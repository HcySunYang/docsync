{
  "name": "docsync-vscode",
  "displayName": "DocSync",
  "description": "Sync markdown docs across machines using a GitHub repo. Browse, push, pull, move, and delete docs from the Explorer sidebar. Drag files to Copilot Chat for context.",
  "version": "0.1.0",
  "publisher": "HcySunYang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HcySunYang/docsync"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "docsyncExplorer",
          "name": "DOCSYNC"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "docsyncExplorer",
        "contents": "No DocSync configuration found.\n[Initialize DocSync](command:docsync.init)",
        "when": "!docsync.loading && !docsync.initialized"
      }
    ],
    "commands": [
      {
        "command": "docsync.refresh",
        "title": "Sync from Remote",
        "icon": "$(sync)"
      },
      {
        "command": "docsync.pullAll",
        "title": "Pull All",
        "icon": "$(cloud-download)"
      },
      {
        "command": "docsync.pushFile",
        "title": "Push to DocSync",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "docsync.viewFile",
        "title": "View File"
      },
      {
        "command": "docsync.deleteFile",
        "title": "Delete"
      },
      {
        "command": "docsync.moveFile",
        "title": "Move to..."
      },
      {
        "command": "docsync.init",
        "title": "DocSync: Initialize"
      },
      {
        "command": "docsync.newFolder",
        "title": "New Folder",
        "icon": "$(new-folder)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "docsync.refresh",
          "when": "view == docsyncExplorer",
          "group": "navigation"
        },
        {
          "command": "docsync.newFolder",
          "when": "view == docsyncExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "docsync.viewFile",
          "when": "view == docsyncExplorer && viewItem == file"
        },
        {
          "command": "docsync.deleteFile",
          "when": "view == docsyncExplorer && viewItem == file"
        },
        {
          "command": "docsync.moveFile",
          "when": "view == docsyncExplorer && viewItem == file"
        },
        {
          "command": "docsync.newFolder",
          "when": "view == docsyncExplorer && viewItem == folder"
        },
        {
          "command": "docsync.deleteFile",
          "when": "view == docsyncExplorer && viewItem == folder"
        }
      ],
      "explorer/context": [
        {
          "command": "docsync.pushFile",
          "when": "resourceExtname == .md || resourceExtname == .mdx",
          "group": "docsync@1"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "dev": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "package": "npx vsce package --no-dependencies",
    "publish": "node publish.js"
  },
  "dependencies": {
    "docsync-cli": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.0",
    "typescript": "^6.0.2"
  }
}
